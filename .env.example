PORT=3000
UPLOAD_DIR=uploads
CONVERTED_DIR=converted
MAX_FILE_SIZE_MB=50
FILE_MAX_AGE_MINUTES=30
CLEANUP_INTERVAL_MINUTES=60
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
# Tidak wajib diubah: frontend sekarang disajikan oleh server yang sama (satu origin),
# jadi CORS ini hanya relevan kalau Anda ingin mengakses API dari luar (mis. Postman
# di domain lain atau frontend terpisah). Biarkan default kalau tidak yakin.
CORS_ORIGIN=http://localhost:3000
